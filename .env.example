# ----------------------------------------------------------------------------
# Portage — environment configuration (copy to `.env`; `.env` is gitignored).
# 12-factor: every service reads its config from here. Same Postgres for both the
# domain tables (SQLAlchemy/asyncpg) and LangGraph's checkpointer (psycopg).
# ----------------------------------------------------------------------------

# --- Postgres ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=portage
POSTGRES_USER=portage
POSTGRES_PASSWORD=portage

# --- Worker / queue ---
WORKER_ID=worker-1
# A 'running' job whose heartbeat is older than the lease is treated as orphaned
# (its worker crashed) and re-claimed — this is what makes kill/restart resume.
JOB_LEASE_SECONDS=15
HEARTBEAT_INTERVAL_SECONDS=5
WORKER_POLL_INTERVAL_SECONDS=2

# --- Agent (Phase 1: Ingest -> Verify -> Report) ---
# Default pre-test delay in the Verify node. 0 for normal runs; the crash-recovery demo
# raises it per-job (job config `verify_delay_seconds`) to get a kill window mid-Verify.
VERIFY_PRE_DELAY_SECONDS=0

# --- LLM (Phase 2: Execute node, via LiteLLM) ---
# Provider is config, not code. Documented default = Claude Sonnet 4.6 on Bedrock; set
# LLM_DRIVER_MODEL + the matching provider creds to verify with whatever you have. Examples:
#   Bedrock : LLM_DRIVER_MODEL=bedrock/us.anthropic.claude-sonnet-4-6-v1:0
#             AWS_ACCESS_KEY_ID=... AWS_SECRET_ACCESS_KEY=... AWS_REGION_NAME=us-east-1
#   Azure   : LLM_DRIVER_MODEL=azure/<deployment>   (e.g. a gpt-4o deployment)
#             AZURE_API_KEY=... AZURE_API_BASE=https://<resource>.openai.azure.com
#             AZURE_API_VERSION=2024-08-01-preview
#   Gemini  : LLM_DRIVER_MODEL=gemini/gemini-2.5-flash   GEMINI_API_KEY=...
#   Anthropic: LLM_DRIVER_MODEL=anthropic/claude-sonnet-4-6   ANTHROPIC_API_KEY=...
#   Z.AI    : LLM_DRIVER_MODEL=zai/glm-4.7-flash   ZAI_API_KEY=...
# THINKING/REASONING MODELS (GLM-4.7, o-series, …): reasoning tokens count against
# max_tokens — with the 4096 default the model can return EMPTY content on large
# migration prompts (observed). Set LLM_MAX_TOKENS=16000 (and a higher
# LLM_TIMEOUT_SECONDS) when the driver or escalation model is a thinking model.
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT_SECONDS=120
# Leave unset to use the Bedrock default. The Execute node runs in the worker container
# (which has network); the test sandbox stays network-off.
# LLM_DRIVER_MODEL=azure/your-gpt4o-deployment
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=2024-08-01-preview
# EXECUTE_TASK_DELAY_SECONDS=0   # raise per-job to get a kill window mid-Execute
# For the escalation tier, set LLM_ESCALATION_MODEL the same way (defaults to Opus on
# Bedrock). With a single provider/deployment, point it at the same model — the ladder
# machinery still runs and is recorded per attempt.
# LLM_ESCALATION_MODEL=azure/your-gpt4o-deployment
# Optional public-safe display names for logs/attempts_log — set these if the model string
# contains a private deployment id you don't want persisted or shown in the dashboard.
# LLM_DRIVER_MODEL_LABEL=GPT-4o
# LLM_ESCALATION_MODEL_LABEL=GPT-4o
# Optional public display labels: what the dashboard / attempts_log / report.json show
# instead of the raw model string — useful when the deployment name is private.
# LLM_DRIVER_MODEL_LABEL=GPT-4o
# LLM_ESCALATION_MODEL_LABEL=GPT-4o

# --- Recovery budgets (Phase 3; see config.py for semantics) ---
# ESCALATE_AFTER_ATTEMPTS=2
# MAX_TASK_ATTEMPTS=3
# MAX_RECOVER_VISITS=4

# --- Auth & demo protection (Phase 7; rev-C free-demo model) ---
# "disabled" (local default): every request acts as a local admin — dev flows and DoD
# scripts need zero ceremony. "github": full enforcement (hosted deployments).
AUTH_MODE=disabled
# GitHub OAuth app (Settings -> Developer settings -> OAuth Apps). Callback URL must be
# <api-origin>/auth/github/callback.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# JWT_SECRET=change-me-in-hosted-mode          # HS256; 15-min access tokens
# FRONTEND_ORIGIN=http://localhost:3000        # OAuth callback redirects here
# CORS_ORIGINS=http://localhost:3000           # comma-separated allowlist (never * hosted)
# Demo-uptime limits (rev-C: protect the GPT-4o quota, not revenue):
# MAX_CONCURRENT_JOBS_PER_USER=1
# MAX_JOBS_PER_DAY_PER_USER=5
# JOB_COST_CEILING_USD=2.0                     # runaway retry spiral aborts gracefully
# GLOBAL_DAILY_SPEND_CAP_USD=0                 # 0 = disabled; set from week-1 usage

# --- Frontend (browser -> API; host-mapped port, not the compose service name) ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
