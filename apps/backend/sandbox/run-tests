#!/usr/bin/env sh
# Test runner executed inside the ephemeral sandbox (cwd = the mounted workspace/worktree).
# Best-effort offline editable install (real repos import the installed package); the
# fixture also works via pytest's `pythonpath` setting, so install failure is non-fatal.
# Emits JUnit XML (built into pytest — robust across versions); the Verify node parses it.
#
# Extra args are pytest test targets: Verify passes the blast-radius-affected subset,
# Integrate passes none (the full suite).

if [ -f pyproject.toml ] || [ -f setup.py ]; then
    if pip install -e . --no-build-isolation --no-index --no-deps >/dev/null 2>&1; then
        echo "[run-tests] installed package (editable, offline)"
    else
        echo "[run-tests] editable install skipped (using pytest pythonpath)"
    fi
fi

# Repo root on PYTHONPATH — the offline stand-in for `pip install -e .` in repos with no
# packaging manifest (tests importing a top-level package would otherwise fail collection).
export PYTHONPATH="$PWD${PYTHONPATH:+:$PYTHONPATH}"

# Optional pre-test setup from the corpus entry (via test_env), e.g. creating the schema
# a DB-backed suite assumes exists — the offline stand-in for the repo's documented
# "provision a test database" step. Runs inside the network-off sandbox; failure is fatal
# (a half-provisioned suite would produce misleading results).
if [ -n "${PORTAGE_TEST_SETUP:-}" ]; then
    echo "[run-tests] setup: $PORTAGE_TEST_SETUP"
    sh -c "$PORTAGE_TEST_SETUP" || exit 70
fi

# Write the report to a stable path the worker reads back off the shared volume.
# Do not let a non-zero pytest exit (failing tests) abort before the report is flushed —
# pytest writes the XML before exiting, so we just propagate its code afterwards.
pytest --junit-xml=.portage-report.xml -q "$@"
exit $?
