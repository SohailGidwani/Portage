# portage-sandbox — the ephemeral, network-off test-runner image.
# Built via the compose `tools` profile (NOT started by `docker compose up`); the worker
# `docker run`s it per verification. Untrusted repo code only ever executes in here.
#
# Deps are baked in so tests run with `--network none` (no pip fetches at run time). The set
# covers both fixtures: pydantic (Phase 1) and the Flask→FastAPI migration (Phase 2) — the
# migrated app imports fastapi/starlette and its TestClient needs httpx; flask is kept so a
# pre-migration baseline can also run offline. The LLM is told this is the only set available.
FROM python:3.12-slim-bookworm

# Pinned so the runner image is reproducible. Two layers of deps:
#   core     — the migration pair (flask pre / fastapi post) + pytest tooling
#   corpus   — what curated corpus repos need to run offline (see corpus/README.md; every
#              addition is pinned and noted on the corpus entry that needs it)
RUN pip install --no-cache-dir \
        "pytest==8.3.4" \
        "pydantic==2.13.4" \
        "fastapi==0.115.6" \
        "starlette==0.41.3" \
        "uvicorn==0.34.0" \
        "httpx==0.28.1" \
        "flask==3.1.0" \
        "setuptools==75.6.0" \
        "wheel==0.45.1" \
    && pip install --no-cache-dir \
        "sqlalchemy==2.0.36" \
        "flask-login==0.6.3" \
        "marshmallow==3.23.1" \
        "bcrypt==4.2.1" \
        "python-dotenv==1.0.1" \
        "email-validator==2.2.0" \
        "bleach==6.2.0" \
        "flask-restx==1.3.0" \
        "flask-sqlalchemy==3.1.1" \
        "flask-babel==4.0.0" \
        "flask-cors==5.0.0" \
        "flask-mail==0.9.1" \
        "flask-migrate==4.0.5" \
        "flask-moment==1.0.5" \
        "flask-httpauth==4.8.0" \
        "flask-wtf==1.2.1" \
        "pyjwt==2.8.0" \
        "langdetect==1.0.9" \
        "elasticsearch==8.11.0" \
        "rq==1.15.1" \
        "celery==5.4.0" \
        "redis==5.2.1" \
        "requests==2.32.3"

COPY run-tests /usr/local/bin/run-tests
RUN chmod +x /usr/local/bin/run-tests

# Default workdir is the mounted repo; the worker overrides -w to the workspace/worktree.
WORKDIR /repo
CMD ["run-tests"]
